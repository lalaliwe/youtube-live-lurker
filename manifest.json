{
  "manifest_version": 3,
  "name": "YouTube Live Lurker",
  "version": "1.0.0",
  "description": "AutoOpen and notifys the user when Streamers go live.",
  "permissions": ["alarms", "notifications", "storage", "tabs"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.googleapis.com/*",
    "https://yt3.googleusercontent.com/*",
    "https://yt3.ggpht.com/*",
    "http://127.0.0.1/*",
    "https://holodex.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://www.youtube.com https://www.googleapis.com https://holodex.net ws://127.0.0.1:38517"
  },
  "action": {
    "default_title": "YouTube Live Lurker",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png"
  }
}
